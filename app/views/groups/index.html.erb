<% if notice then %>
  <div class='alert alert-primary alert-dismissible fade show'>
    <%= notice %>
  </div>
<% end %>
<h1 class='h2 mb-3'>Groups</h1>

<div id="group" class='list-group'>
  <% @groups.each do |group| %>
    <%= link_to group_path(group), class: 'list-group-item list-group-item-action d-flex justify-content-between' do %>
      <div class='fs-5'>
        <i class='bi bi-tag me-1'></i>
        <span><%= group.cn %></span>
        <small class='fs-6 text-muted ms-1'><%= group.gid_number %></small>
      </div>
    <% end %>
  <% end %>
</div>

<%= link_to 'Add new group', new_group_path, class: 'btn btn-primary mt-5' %>
