<% if notice then %>
  <div class='alert alert-primary alert-dismissible fade show'>
    <%= notice %>
  </div>
<% end %>
<% unless @group.errors.empty? then %>
  <div class='alert alert-danger alert-dismissible fade show'>
    <% @group.errors.full_messages.each do |message| %>
      <%= message %><br/>
    <% end %>
  </div>
<% end %>

<%= form_with(url: action, method: method) do |form| %>
  <div class='card mb-4'>
    <div class='card-header bg-transparent'>
      <div class='fs-4 mb-0'>
        <i class='bi bi-tag'></i>
        Group
      </div>
    </div>
    <div class='card-body'>
      <div class='row form-group mb-3'>
        <label class='form-label col-2 text-muted'>name</label>
        <div class='col-10'>
          <%= text_field :group, :cn, class: 'form-control' %>
        </div>
      </div>
      <div class='row form-group mb-3'>
        <label class='form-label col-2 text-muted'>gid</label>
        <div class='col-10'>
          <%= text_field :group, :gid_number, readonly: true, class: 'form-control-plaintext px-2' %>
        </div>
      </div>
      <div class='row form-group mb-3'>
        <label class='form-label col-2 text-muted'>members</label>
        <div class='col-10'>
          <ul class='list-group'>
            <% User.all(order: 'asc').each do |user| %>
              <li class='list-group-item'>
                <%= check_box :group, :member_uid, {multiple: true, checked: user.member_of?(@group.cn), class: 'me-2'}, user.cn, nil %>
                <%= user.cn %>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <%= form.submit 'Submit group', class: 'btn btn-primary' %>
<% end %>
