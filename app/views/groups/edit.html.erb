<%= render 'form', group: @group, action: group_path(@group), method: :patch %>

<div class='fs-4 mt-5'>
  <i class='bi bi-eraser'></i>
  Delete group
</div>
<p class='text-muted mb-0'>Once you delete your account, there is no going back.</p>
<%= button_to(
  'Delete this group', group_path(@group), method: 'delete',
  form: {data: {turbo_confirm: 'This will permanently delete this profile. Are you sure you wish to continue?'}},
  class: "btn btn-danger mt-2 #{'disabled' if @group.reserved?}",
) %>
